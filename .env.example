VITE_SUPABASE_URL=
# Use either (same key from Supabase → Project Settings → API → anon public):
VITE_SUPABASE_ANON_KEY=
# VITE_SUPABASE_PUBLISHABLE_KEY=

# Supplier API URL + key: set ONLY as Edge Function secrets (not in Vite):
# supabase secrets set SUPPLIER_API_URL=https://...
# supabase secrets set SUPPLIER_API_KEY=...
# supabase secrets set SUPABASE_SERVICE_ROLE_KEY=...   (service role — server only)
# Optional: comma-separated origins for CORS on supplier-proxy
# ALLOWED_ORIGINS=http://localhost:5173,https://yourdomain.com
